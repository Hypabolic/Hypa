{
  "filterDefinition": {
    "id": "match-output-clean-success",
    "stages": [
      {
        "kind": "MatchOutput",
        "pattern": "Build complete!",
        "replacement": "ok (build complete)",
        "guard": "(?i)([1-9]\\d* warnings?|[1-9]\\d* errors?|error:)"
      },
      { "kind": "KeepLines", "pattern": "^Build" }
    ]
  }
}
